////////////////////////////////////////////////////////////
// Project     : WarehousePro Logistics
// Sprint      : 03
// Module      : Resource Groups
// Version     : 1.0
// Author      : Nhlanhla M
// Description : Deploys Enterprise Resource Groups
////////////////////////////////////////////////////////////

////////////////////////////////////////////////////////////
// MODULE INFORMATION
////////////////////////////////////////////////////////////
// Scope      : Subscription
// Depends On : None
// Deploys    : Resource Groups
// Returns    : Resource Group Names
////////////////////////////////////////////////////////////
targetScope = 'subscription'
////////////////////////////////////////////////////////////
// PARAMETERS
////////////////////////////////////////////////////////////

@description('Deployment location')
param location string

@description('Environment name')
param environment string

////////////////////////////////////////////////////////////
// VARIABLES
////////////////////////////////////////////////////////////

var resourceGroupNames = [
  'Networking'
  'Identity'
  'Management'
  'Monitoring'
  'SharedServices'
  'WH-JHB'
  'WH-DBN'
  'WH-CPT'
]

////////////////////////////////////////////////////////////
// RESOURCES
////////////////////////////////////////////////////////////

resource resourceGroups 'Microsoft.Resources/resourceGroups@2024-11-01' = [for rg in resourceGroupNames: {
  name: 'RG-${rg}-${environment}'
  location: location
}]

////////////////////////////////////////////////////////////
// OUTPUTS
////////////////////////////////////////////////////////////

output deployedResourceGroups array = [
  for rg in resourceGroupNames: 'RG-${rg}-${environment}'
]
